{
  "name": "noble-bip32ed25519",
  "version": "0.1.0",
  "description": "Pure TypeScript BIP32-Ed25519 key derivation using @noble/curves",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./sodium": {
      "import": "./dist/sodium-shim.js",
      "types": "./dist/sodium-shim.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "prepublishOnly": "npm run clean && npm run build && npm test",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@noble/curves": "^1.8.0",
    "@noble/hashes": "^1.7.0"
  },
  "devDependencies": {
    "@stricahq/bip32ed25519": "^1.1.0",
    "bip39": "^3.1.0",
    "libsodium-wrappers-sumo": "^0.8.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "bip32",
    "ed25519",
    "cardano",
    "key-derivation",
    "noble",
    "cryptocurrency"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mwaddip/noble-bip32ed25519.git"
  },
  "engines": {
    "node": ">=16"
  },
  "license": "MIT"
}
